<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Main app theme — used at runtime once the splash screen exits. -->
    <style name="Theme.Meraki" parent="android:Theme.Material.Light.NoActionBar" />

    <!--
        Splash-screen entry theme applied to MainActivity in the manifest.

        windowSplashScreenBackground   — dark navy matching the video's first frame,
                                         so the OS splash and the ExoPlayer video are
                                         visually indistinguishable. No white flash.
        windowSplashScreenAnimatedIcon — a fully-transparent placeholder so no icon
                                         appears on the OS splash; the video is the
                                         only branded element the user sees.
        postSplashScreenTheme          — the real app theme applied the moment
                                         installSplashScreen() dismisses the system
                                         splash and Compose takes over.
    -->
    <style name="Theme.Meraki.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0D1B2A</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon_transparent</item>
        <item name="postSplashScreenTheme">@style/Theme.Meraki</item>
    </style>

</resources>